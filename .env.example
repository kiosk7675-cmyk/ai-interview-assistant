# ===== InterviewPrep 环境配置模板 =====
# 复制此文件为 .env 并填入真实值

# 应用配置
APP_NAME=InterviewPrep
DEBUG=True
HOST=0.0.0.0
PORT=9900

# ===== DeepSeek Chat API 配置 =====
# 从 https://platform.deepseek.com 获取
DASHSCOPE_API_KEY=sk-your-deepseek-api-key
DASHSCOPE_API_BASE=https://api.deepseek.com/v1
DASHSCOPE_MODEL=deepseek-chat

# 嵌入模型（可选，默认使用本地 FastEmbed）
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4

# ChromaDB 配置（本地持久化）
CHROMA_PERSIST_DIR=./chroma_db

# RAG 配置
RAG_TOP_K=3
RAG_MODEL=deepseek-chat

# 文档分块配置
CHUNK_MAX_SIZE=800
CHUNK_OVERLAP=100
